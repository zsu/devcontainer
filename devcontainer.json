{
  "name": "AI Dev",
  "build": {
    "context": ".",
    "dockerfile": "Dockerfile"
  },
  "workspaceFolder": "/workspace",
  "workspaceMount": "source=${localWorkspaceFolder},target=/workspace,type=bind,consistency=cached",
  "mounts": [
    "source=devcontainer-commandhistory-${localWorkspaceFolderBasename},target=/commandhistory,type=volume",
    "source=devcontainer-claude-${localWorkspaceFolderBasename},target=/home/node/.claude,type=volume",
    "source=devcontainer-config-${localWorkspaceFolderBasename},target=/home/node/.config,type=volume"
  ],
  "runArgs": ["--init"],
  "remoteUser": "node",
  "updateRemoteUserUID": true,
  "shutdownAction": "stopContainer",
  "containerEnv": {
    "CLAUDE_CONFIG_DIR": "/home/node/.claude",
    "XDG_CONFIG_HOME": "/home/node/.config",
    "HISTFILE": "/commandhistory/.bash_history"
  },
  "customizations": {
    "vscode": {
      "settings": {
        "terminal.integrated.defaultProfile.linux": "bash"
      },
      "extensions": [
        "anthropic.claude-code",
        "eamodio.gitlens",
        "esbenp.prettier-vscode"
      ]
    }
  },
  "forwardPorts": [
    5000
  ],
  "portsAttributes": {
    "5000": {
      "label": "App",
      "onAutoForward": "notify"
    }
  },
  "postCreateCommand": "git config --global submodule.recurse true && bash -lc \"mkdir -p ~/.ssh && chmod 700 ~/.ssh && ssh-keyscan github.com >> ~/.ssh/known_hosts 2>/dev/null && python3 --version && pip3 --version && gh --version | head -n 1 && zellij --version\"",
  "postStartCommand": "sudo service cron start"
}
